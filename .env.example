# Workflow Builder - Environment Configuration
# Copy this file to .env and update values as needed

# Database Configuration
DB_USER=workflow_user
DB_PASSWORD=workflow_password
DB_HOST=postgres
DB_PORT=5432

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Mail Configuration
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# OAuth2 Configuration (Optional)
OAUTH2_CLIENT_SECRET=your-client-secret
OAUTH2_ISSUER_URI=https://keycloak:8080/auth/realms/workflow
OAUTH2_AUTH_URI=https://keycloak:8080/auth/realms/workflow/protocol/openid-connect/auth
OAUTH2_TOKEN_URI=https://keycloak:8080/auth/realms/workflow/protocol/openid-connect/token
OAUTH2_USER_INFO_URI=https://keycloak:8080/auth/realms/workflow/protocol/openid-connect/userinfo

# JWT Configuration
JWT_SECRET=mySecretKeyForJWTTokenGenerationAndValidationPurposeOnly
JWT_EXPIRATION=86400000

# Service Ports
WORKFLOW_SERVICE_PORT=8001
APPROVAL_SERVICE_PORT=8002
TASK_SERVICE_PORT=8003
NOTIFICATION_SERVICE_PORT=8004
API_GATEWAY_PORT=8000

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin
